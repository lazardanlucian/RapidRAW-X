{
  "name": "RapidRAW-X",
  "build": {
    "dockerfile": "Dockerfile"
  },

  // Forward the Tauri/Vite dev server port
  "forwardPorts": [1420],
  "portsAttributes": {
    "1420": {
      "label": "Vite Dev Server",
      "onAutoForward": "silent"
    }
  },

  // Make Android SDK env vars available to every terminal/task
  "remoteEnv": {
    "ANDROID_HOME": "/opt/android-sdk",
    "NDK_HOME": "/opt/android-sdk/ndk/27.2.12479018",
    "JAVA_HOME": "/usr/lib/jvm/java-17-openjdk-amd64"
  },

  // Install npm dependencies and add Android Rust cross-compilation targets.
  // The rust-toolchain.toml in src-tauri will automatically activate Rust 1.94.0.
  "postCreateCommand": "npm install && rustup target add aarch64-linux-android armv7-linux-androideabi i686-linux-android x86_64-linux-android",

  "customizations": {
    "vscode": {
      "extensions": [
        // Tauri & Rust
        "tauri-apps.tauri-vscode",
        "rust-lang.rust-analyzer",
        // Frontend
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.vscode-typescript-next",
        // Android
        "mathiasfrohlich.kotlin"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "rust-analyzer.check.command": "clippy"
      }
    }
  },

  "remoteUser": "vscode"
}
